<?xml version="1.0" encoding="utf-8" ?>
<ContentPage xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             xmlns:model="clr-namespace:Renamer.UI.Plans"
             x:Class="Renamer.UI.MainPage">
    <Grid RowDefinitions="Auto,*"
          Padding="24"
          RowSpacing="18">
        <VerticalStackLayout Spacing="6">
            <Label Text="Plan Generation, Preview, and Apply"
                   FontSize="32"
                   FontAttributes="Bold"
                   SemanticProperties.HeadingLevel="Level1" />
            <Label Text="Move between generation, preview, and apply at any time. Each step keeps its own status while the active workspace fills the right panel."
                   FontSize="14"
                   TextColor="{AppThemeBinding Light=#5C5C5C, Dark=#B8B8B8}" />
        </VerticalStackLayout>

        <Grid Grid.Row="1"
              ColumnDefinitions="280,*"
              ColumnSpacing="18">
            <ScrollView>
                <VerticalStackLayout Spacing="16">
                    <Border Padding="16"
                            Background="{AppThemeBinding Light=#F8FAFC, Dark=#111827}">
                        <VerticalStackLayout Spacing="8">
                            <Label Text="Workflow"
                                   FontSize="18"
                                   FontAttributes="Bold" />
                            <Label Text="Select any step to work in that area. Status shows whether the step needs input, hit an error, or completed successfully."
                                   FontSize="13"
                                   TextColor="{AppThemeBinding Light=#475569, Dark=#CBD5E1}" />
                        </VerticalStackLayout>
                    </Border>

                    <Border Padding="14">
                        <Border.GestureRecognizers>
                            <TapGestureRecognizer Tapped="OnGenerateStepTapped" />
                        </Border.GestureRecognizers>
                        <Border.Triggers>
                            <DataTrigger TargetType="Border"
                                         Binding="{Binding GenerateStep.IsSelected}"
                                         Value="True">
                                <Setter Property="Stroke" Value="#0F4C81" />
                                <Setter Property="Background" Value="{AppThemeBinding Light=#E0F2FE, Dark=#1E3A5F}" />
                            </DataTrigger>
                        </Border.Triggers>
                        <VerticalStackLayout Spacing="10">
                            <Grid ColumnDefinitions="*,Auto"
                                  ColumnSpacing="10">
                                <Label Text="{Binding GenerateStep.Title}"
                                       FontSize="16"
                                       FontAttributes="Bold" />
                                <Label Grid.Column="1"
                                       Text="{Binding GenerateStep.StatusText}"
                                       FontSize="11"
                                       FontAttributes="Bold"
                                       Padding="8,4"
                                       BackgroundColor="{AppThemeBinding Light=#E2E8F0, Dark=#334155}"
                                       TextColor="{Binding GenerateStep.StatusColor}"
                                       HorizontalOptions="End"
                                       VerticalOptions="Start" />
                            </Grid>
                            <Label Text="{Binding GenerateStep.Description}"
                                   FontSize="13"
                                   TextColor="{AppThemeBinding Light=#475569, Dark=#CBD5E1}" />
                        </VerticalStackLayout>
                    </Border>

                    <Border Padding="14">
                        <Border.GestureRecognizers>
                            <TapGestureRecognizer Tapped="OnPreviewStepTapped" />
                        </Border.GestureRecognizers>
                        <Border.Triggers>
                            <DataTrigger TargetType="Border"
                                         Binding="{Binding PreviewStep.IsSelected}"
                                         Value="True">
                                <Setter Property="Stroke" Value="#0F4C81" />
                                <Setter Property="Background" Value="{AppThemeBinding Light=#E0F2FE, Dark=#1E3A5F}" />
                            </DataTrigger>
                        </Border.Triggers>
                        <VerticalStackLayout Spacing="10">
                            <Grid ColumnDefinitions="*,Auto"
                                  ColumnSpacing="10">
                                <Label Text="{Binding PreviewStep.Title}"
                                       FontSize="16"
                                       FontAttributes="Bold" />
                                <Label Grid.Column="1"
                                       Text="{Binding PreviewStep.StatusText}"
                                       FontSize="11"
                                       FontAttributes="Bold"
                                       Padding="8,4"
                                       BackgroundColor="{AppThemeBinding Light=#E2E8F0, Dark=#334155}"
                                       TextColor="{Binding PreviewStep.StatusColor}"
                                       HorizontalOptions="End"
                                       VerticalOptions="Start" />
                            </Grid>
                            <Label Text="{Binding PreviewStep.Description}"
                                   FontSize="13"
                                   TextColor="{AppThemeBinding Light=#475569, Dark=#CBD5E1}" />
                        </VerticalStackLayout>
                    </Border>

                    <Border Padding="14">
                        <Border.GestureRecognizers>
                            <TapGestureRecognizer Tapped="OnApplyStepTapped" />
                        </Border.GestureRecognizers>
                        <Border.Triggers>
                            <DataTrigger TargetType="Border"
                                         Binding="{Binding ApplyStep.IsSelected}"
                                         Value="True">
                                <Setter Property="Stroke" Value="#0F4C81" />
                                <Setter Property="Background" Value="{AppThemeBinding Light=#E0F2FE, Dark=#1E3A5F}" />
                            </DataTrigger>
                        </Border.Triggers>
                        <VerticalStackLayout Spacing="10">
                            <Grid ColumnDefinitions="*,Auto"
                                  ColumnSpacing="10">
                                <Label Text="{Binding ApplyStep.Title}"
                                       FontSize="16"
                                       FontAttributes="Bold" />
                                <Label Grid.Column="1"
                                       Text="{Binding ApplyStep.StatusText}"
                                       FontSize="11"
                                       FontAttributes="Bold"
                                       Padding="8,4"
                                       BackgroundColor="{AppThemeBinding Light=#E2E8F0, Dark=#334155}"
                                       TextColor="{Binding ApplyStep.StatusColor}"
                                       HorizontalOptions="End"
                                       VerticalOptions="Start" />
                            </Grid>
                            <Label Text="{Binding ApplyStep.Description}"
                                   FontSize="13"
                                   TextColor="{AppThemeBinding Light=#475569, Dark=#CBD5E1}" />
                        </VerticalStackLayout>
                    </Border>
                </VerticalStackLayout>
            </ScrollView>

            <Border Grid.Column="1"
                    Padding="16">
                <ScrollView>
                    <Grid>
                        <VerticalStackLayout Spacing="18"
                                             IsVisible="{Binding IsGenerateStepActive}">
                            <VerticalStackLayout Spacing="4">
                                <Label Text="Generate Plan"
                                       FontSize="24"
                                       FontAttributes="Bold" />
                                <Label Text="Pick the source root and output folder, then generate a plan artifact for the rest of the workflow."
                                       FontSize="13"
                                       TextColor="{AppThemeBinding Light=#475569, Dark=#CBD5E1}" />
                            </VerticalStackLayout>

                            <Border Padding="16">
                                <VerticalStackLayout Spacing="12">
                                    <Label Text="Generate Plan"
                                           FontSize="18"
                                           FontAttributes="Bold" />
                                    <Label Text="Select the source root folder and destination folder for the generated plan artifact."
                                           FontSize="13" />

                                    <VerticalStackLayout Spacing="6">
                                        <Label Text="Root Folder"
                                               FontAttributes="Bold" />
                                        <Entry Text="{Binding GenerationRootPath}"
                                               Placeholder="/path/to/photo-root"
                                               ClearButtonVisibility="WhileEditing" />
                                        <Button Text="Browse Root Folder"
                                                Clicked="OnBrowseGenerationRootClicked" />
                                    </VerticalStackLayout>

                                    <VerticalStackLayout Spacing="6">
                                        <Label Text="Output Folder"
                                               FontAttributes="Bold" />
                                        <Entry Text="{Binding GenerationOutputDirectoryPath}"
                                               Placeholder="/path/to/output-folder"
                                               ClearButtonVisibility="WhileEditing" />
                                        <Button Text="Browse Output Folder"
                                                Clicked="OnBrowseGenerationOutputDirectoryClicked" />
                                    </VerticalStackLayout>

                                    <VerticalStackLayout Spacing="6">
                                        <Label Text="Plan File Name"
                                               FontAttributes="Bold" />
                                        <Entry Text="{Binding PlanFileName}"
                                               Placeholder="rename-plan.json"
                                               ClearButtonVisibility="WhileEditing" />
                                    </VerticalStackLayout>

                                    <VerticalStackLayout Spacing="4">
                                        <Label Text="Generated Plan Path"
                                               FontAttributes="Bold" />
                                        <Label Text="{Binding GeneratedPlanPathPreview}"
                                               FontSize="12"
                                               LineBreakMode="WordWrap"
                                               TextColor="{AppThemeBinding Light=#0F4C81, Dark=#8CC8FF}" />
                                    </VerticalStackLayout>

                                    <HorizontalStackLayout Spacing="10">
                                        <Button Text="Generate and Load"
                                                Clicked="OnGeneratePlanClicked"
                                                IsEnabled="{Binding CanGenerate}" />
                                        <ActivityIndicator IsRunning="{Binding IsGenerating}"
                                                           IsVisible="{Binding IsGenerating}"
                                                           VerticalOptions="Center" />
                                    </HorizontalStackLayout>

                                    <Label Text="{Binding GenerationStatusMessage}"
                                           FontSize="13" />
                                </VerticalStackLayout>
                            </Border>

                            <Border Padding="16"
                                    IsVisible="{Binding HasGenerationError}">
                                <VerticalStackLayout Spacing="8">
                                    <Label Text="{Binding GenerationErrorTitle}"
                                           FontSize="16"
                                           FontAttributes="Bold"
                                           TextColor="#9A3412" />
                                    <Label Text="{Binding GenerationErrorMessage}"
                                           FontSize="13" />
                                </VerticalStackLayout>
                            </Border>
                        </VerticalStackLayout>

                        <VerticalStackLayout Spacing="18"
                                             IsVisible="{Binding IsPreviewStepActive}">
                            <VerticalStackLayout Spacing="4">
                                <Label Text="Preview Plan"
                                       FontSize="24"
                                       FontAttributes="Bold" />
                                <Label Text="Load a plan artifact, review the summary, and inspect each planned rename operation."
                                       FontSize="13"
                                       TextColor="{AppThemeBinding Light=#475569, Dark=#CBD5E1}" />
                            </VerticalStackLayout>

                            <Border Padding="16">
                                <VerticalStackLayout Spacing="12">
                                    <Label Text="Plan Artifact"
                                           FontSize="18"
                                           FontAttributes="Bold" />
                                    <Label Text="Select or paste a path to a rename-plan.json file."
                                           FontSize="13" />
                                    <Entry Text="{Binding PlanPath}"
                                           Placeholder="/path/to/rename-plan.json"
                                           ClearButtonVisibility="WhileEditing" />
                                    <HorizontalStackLayout Spacing="10">
                                        <Button Text="Browse"
                                                Clicked="OnBrowseClicked" />
                                        <Button Text="Load Preview"
                                                Clicked="OnLoadClicked" />
                                    </HorizontalStackLayout>
                                    <Label Text="{Binding StatusMessage}"
                                           FontSize="13" />
                                </VerticalStackLayout>
                            </Border>

                            <Border Padding="16"
                                    IsVisible="{Binding HasError}">
                                <VerticalStackLayout Spacing="8">
                                    <Label Text="Unable To Load Plan"
                                           FontSize="16"
                                           FontAttributes="Bold"
                                           TextColor="#9A3412" />
                                    <Label Text="{Binding ErrorMessage}"
                                           FontSize="13" />
                                </VerticalStackLayout>
                            </Border>

                            <Border Padding="16">
                                <VerticalStackLayout Spacing="14">
                                    <Label Text="Summary"
                                           FontSize="18"
                                           FontAttributes="Bold" />

                                    <VerticalStackLayout Spacing="4">
                                        <Label Text="Root Path"
                                               FontAttributes="Bold" />
                                        <Label Text="{Binding RootPath}"
                                               LineBreakMode="WordWrap"
                                               TextColor="{AppThemeBinding Light=#0F4C81, Dark=#8CC8FF}"
                                               IsVisible="{Binding CanOpenRootPath}">
                                            <Label.GestureRecognizers>
                                                <TapGestureRecognizer Tapped="OnOpenRootPathTapped" />
                                            </Label.GestureRecognizers>
                                        </Label>
                                        <Label Text="No plan loaded"
                                               IsVisible="{Binding IsIdle}" />
                                    </VerticalStackLayout>

                                    <Grid ColumnDefinitions="*,*"
                                          ColumnSpacing="16">
                                        <VerticalStackLayout Grid.Column="0"
                                                             Spacing="4">
                                            <Label Text="Created At"
                                                   FontAttributes="Bold" />
                                            <Label Text="{Binding CreatedAtDisplay}" />
                                        </VerticalStackLayout>

                                        <VerticalStackLayout Grid.Column="1"
                                                             Spacing="4">
                                            <Label Text="Operations"
                                                   FontAttributes="Bold" />
                                            <Label Text="{Binding OperationCountText}" />
                                        </VerticalStackLayout>
                                    </Grid>

                                    <VerticalStackLayout Spacing="4">
                                        <Label Text="Warnings"
                                               FontAttributes="Bold" />
                                        <Label Text="{Binding WarningCountText}" />
                                    </VerticalStackLayout>
                                </VerticalStackLayout>
                            </Border>

                            <VerticalStackLayout Spacing="12">
                                <Label Text="Operations"
                                       FontSize="18"
                                       FontAttributes="Bold" />

                                <Grid>
                                    <Label Text="No plan loaded yet."
                                           HorizontalOptions="Center"
                                           VerticalOptions="Center"
                                           IsVisible="{Binding IsIdle}" />

                                    <ActivityIndicator IsRunning="{Binding IsLoading}"
                                                       IsVisible="{Binding IsLoading}"
                                                       HorizontalOptions="Center"
                                                       VerticalOptions="Center" />

                                    <CollectionView ItemsSource="{Binding Operations}"
                                                    SelectionMode="None"
                                                    IsVisible="{Binding IsLoaded}">
                                        <CollectionView.ItemTemplate>
                                            <DataTemplate x:DataType="model:PlanOperationItem">
                                                <Border Padding="14"
                                                        Margin="0,0,0,10">
                                                    <VerticalStackLayout Spacing="10">
                                                        <Grid ColumnDefinitions="*,Auto"
                                                              ColumnSpacing="12">
                                                            <VerticalStackLayout Spacing="2">
                                                                <Label Text="{Binding SourceName}"
                                                                       FontSize="16"
                                                                       FontAttributes="Bold" />
                                                                <Label Text="{Binding SourcePath}"
                                                                       FontSize="12"
                                                                       LineBreakMode="WordWrap"
                                                                       TextColor="{AppThemeBinding Light=#5C5C5C, Dark=#B8B8B8}" />
                                                            </VerticalStackLayout>

                                                            <Label Grid.Column="1"
                                                                   Text="{Binding DateRangeText}"
                                                                   FontSize="12"
                                                                   HorizontalTextAlignment="End" />
                                                        </Grid>

                                                        <BoxView HeightRequest="1"
                                                                 BackgroundColor="{AppThemeBinding Light=#D8D8D8, Dark=#3A3A3A}" />

                                                        <VerticalStackLayout Spacing="2">
                                                            <Label Text="{Binding DestinationName}"
                                                                   FontSize="16"
                                                                   FontAttributes="Bold"
                                                                   TextColor="{AppThemeBinding Light=#0F4C81, Dark=#8CC8FF}" />
                                                            <Label Text="{Binding PlannedDestinationPath}"
                                                                   FontSize="12"
                                                                   LineBreakMode="WordWrap"
                                                                   TextColor="{AppThemeBinding Light=#5C5C5C, Dark=#B8B8B8}" />
                                                        </VerticalStackLayout>

                                                        <Grid ColumnDefinitions="*,Auto"
                                                              ColumnSpacing="12">
                                                            <Label Text="{Binding FileCountText}"
                                                                   FontSize="12" />
                                                            <Label Grid.Column="1"
                                                                   Text="{Binding OpId}"
                                                                   FontSize="11"
                                                                   HorizontalTextAlignment="End"
                                                                   TextColor="{AppThemeBinding Light=#808080, Dark=#9C9C9C}" />
                                                        </Grid>
                                                    </VerticalStackLayout>
                                                </Border>
                                            </DataTemplate>
                                        </CollectionView.ItemTemplate>
                                    </CollectionView>
                                </Grid>
                            </VerticalStackLayout>
                        </VerticalStackLayout>

                        <VerticalStackLayout Spacing="18"
                                             IsVisible="{Binding IsApplyStepActive}">
                            <VerticalStackLayout Spacing="4">
                                <Label Text="Apply Plan"
                                       FontSize="24"
                                       FontAttributes="Bold" />
                                <Label Text="Run the loaded plan and inspect the resulting report summary and per-operation outcomes."
                                       FontSize="13"
                                       TextColor="{AppThemeBinding Light=#475569, Dark=#CBD5E1}" />
                            </VerticalStackLayout>

                            <Border Padding="16">
                                <VerticalStackLayout Spacing="12">
                                    <Label Text="Apply"
                                           FontSize="18"
                                           FontAttributes="Bold" />
                                    <Label Text="Apply uses the loaded plan artifact and writes the execution outcome into the report panel."
                                           FontSize="13" />
                                    <HorizontalStackLayout Spacing="10">
                                        <Button Text="Run Apply"
                                                Clicked="OnApplyClicked"
                                                IsEnabled="{Binding CanApply}" />
                                        <ActivityIndicator IsRunning="{Binding IsApplying}"
                                                           IsVisible="{Binding IsApplying}"
                                                           VerticalOptions="Center" />
                                    </HorizontalStackLayout>
                                    <Label Text="{Binding ApplyStatusMessage}"
                                           FontSize="13" />
                                </VerticalStackLayout>
                            </Border>

                            <Border Padding="16"
                                    IsVisible="{Binding HasApplyError}">
                                <VerticalStackLayout Spacing="8">
                                    <Label Text="{Binding ApplyErrorTitle}"
                                           FontSize="16"
                                           FontAttributes="Bold"
                                           TextColor="#9A3412" />
                                    <Label Text="{Binding ApplyErrorMessage}"
                                           FontSize="13" />
                                </VerticalStackLayout>
                            </Border>

                            <Border Padding="16">
                                <VerticalStackLayout Spacing="14">
                                    <Label Text="Apply Summary"
                                           FontSize="18"
                                           FontAttributes="Bold" />

                                    <Grid ColumnDefinitions="*,*"
                                          ColumnSpacing="16">
                                        <VerticalStackLayout Grid.Column="0"
                                                             Spacing="4">
                                            <Label Text="Outcome"
                                                   FontAttributes="Bold" />
                                            <Label Text="{Binding ApplyOutcomeText}" />
                                        </VerticalStackLayout>

                                        <VerticalStackLayout Grid.Column="1"
                                                             Spacing="4">
                                            <Label Text="Drifted"
                                                   FontAttributes="Bold" />
                                            <Label Text="{Binding ApplyDriftedCountText}" />
                                        </VerticalStackLayout>
                                    </Grid>

                                    <Grid ColumnDefinitions="*,*"
                                          ColumnSpacing="16">
                                        <VerticalStackLayout Grid.Column="0"
                                                             Spacing="4">
                                            <Label Text="Started"
                                                   FontAttributes="Bold" />
                                            <Label Text="{Binding ApplyStartedAtDisplay}" />
                                        </VerticalStackLayout>

                                        <VerticalStackLayout Grid.Column="1"
                                                             Spacing="4">
                                            <Label Text="Finished"
                                                   FontAttributes="Bold" />
                                            <Label Text="{Binding ApplyFinishedAtDisplay}" />
                                        </VerticalStackLayout>
                                    </Grid>

                                    <Grid ColumnDefinitions="*,*,*"
                                          ColumnSpacing="16">
                                        <VerticalStackLayout Grid.Column="0"
                                                             Spacing="4">
                                            <Label Text="Success"
                                                   FontAttributes="Bold" />
                                            <Label Text="{Binding ApplySuccessCountText}" />
                                        </VerticalStackLayout>

                                        <VerticalStackLayout Grid.Column="1"
                                                             Spacing="4">
                                            <Label Text="Skipped"
                                                   FontAttributes="Bold" />
                                            <Label Text="{Binding ApplySkippedCountText}" />
                                        </VerticalStackLayout>

                                        <VerticalStackLayout Grid.Column="2"
                                                             Spacing="4">
                                            <Label Text="Failed"
                                                   FontAttributes="Bold" />
                                            <Label Text="{Binding ApplyFailedCountText}" />
                                        </VerticalStackLayout>
                                    </Grid>
                                </VerticalStackLayout>
                            </Border>

                            <VerticalStackLayout Spacing="12">
                                <Label Text="Apply Results"
                                       FontSize="18"
                                       FontAttributes="Bold" />
                                <CollectionView ItemsSource="{Binding ApplyResults}"
                                                SelectionMode="None"
                                                IsVisible="{Binding HasApplyReport}">
                                    <CollectionView.ItemTemplate>
                                        <DataTemplate x:DataType="model:ApplyResultItem">
                                            <Border Padding="14"
                                                    Margin="0,0,0,10">
                                                <VerticalStackLayout Spacing="8">
                                                    <Grid ColumnDefinitions="*,Auto"
                                                          ColumnSpacing="12">
                                                        <VerticalStackLayout Spacing="2">
                                                            <Label Text="{Binding SourceName}"
                                                                   FontSize="16"
                                                                   FontAttributes="Bold" />
                                                            <Label Text="{Binding SourcePath}"
                                                                   FontSize="12"
                                                                   LineBreakMode="WordWrap"
                                                                   TextColor="{AppThemeBinding Light=#5C5C5C, Dark=#B8B8B8}" />
                                                        </VerticalStackLayout>
                                                        <Label Grid.Column="1"
                                                               Text="{Binding StatusText}"
                                                               FontSize="12"
                                                               HorizontalTextAlignment="End" />
                                                    </Grid>

                                                    <VerticalStackLayout Spacing="2">
                                                        <Label Text="Planned Destination"
                                                               FontAttributes="Bold"
                                                               FontSize="12" />
                                                        <Label Text="{Binding PlannedDestinationPath}"
                                                               FontSize="12"
                                                               LineBreakMode="WordWrap" />
                                                    </VerticalStackLayout>

                                                    <VerticalStackLayout Spacing="2">
                                                        <Label Text="Actual Destination"
                                                               FontAttributes="Bold"
                                                               FontSize="12" />
                                                        <Label Text="{Binding ActualDestinationPathText}"
                                                               FontSize="12"
                                                               LineBreakMode="WordWrap" />
                                                    </VerticalStackLayout>

                                                    <VerticalStackLayout Spacing="2">
                                                        <Label Text="Warnings"
                                                               FontAttributes="Bold"
                                                               FontSize="12" />
                                                        <Label Text="{Binding WarningText}"
                                                               FontSize="12"
                                                               LineBreakMode="WordWrap" />
                                                    </VerticalStackLayout>

                                                    <VerticalStackLayout Spacing="2">
                                                        <Label Text="Error"
                                                               FontAttributes="Bold"
                                                               FontSize="12" />
                                                        <Label Text="{Binding ErrorText}"
                                                               FontSize="12"
                                                               LineBreakMode="WordWrap" />
                                                    </VerticalStackLayout>
                                                </VerticalStackLayout>
                                            </Border>
                                        </DataTemplate>
                                    </CollectionView.ItemTemplate>
                                </CollectionView>
                            </VerticalStackLayout>
                        </VerticalStackLayout>
                    </Grid>
                </ScrollView>
            </Border>
        </Grid>
    </Grid>
</ContentPage>
