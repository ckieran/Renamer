<?xml version="1.0" encoding="utf-8" ?>
<ContentPage xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             xmlns:plans="clr-namespace:Renamer.UI.Plans"
             xmlns:strings="clr-namespace:Renamer.UI.Resources.Strings"
             xmlns:views="clr-namespace:Renamer.UI.Views"
             x:Class="Renamer.UI.MainPage"
             x:DataType="plans:IPlanViewModel">

    <ContentPage.MenuBarItems>
        <MenuBarItem Text="View">
            <MenuFlyoutItem x:Name="LightThemeMenuItem"  Text="Light Theme"    Clicked="OnLightThemeClicked" />
            <MenuFlyoutItem x:Name="DarkThemeMenuItem"   Text="Dark Theme"     Clicked="OnDarkThemeClicked" />
            <MenuFlyoutSeparator />
            <MenuFlyoutItem x:Name="SystemThemeMenuItem" Text="System Default" Clicked="OnSystemThemeClicked" />
        </MenuBarItem>
    </ContentPage.MenuBarItems>

    <Grid RowDefinitions="Auto,*"
          Padding="24"
          RowSpacing="18">

        <!-- Header row: title/description left, theme picker right -->
        <Grid ColumnDefinitions="*,Auto">
            <VerticalStackLayout Spacing="6">
                <Label Text="{x:Static strings:AppStrings.MainPageHeading}"
                       FontSize="32"
                       FontAttributes="Bold"
                       SemanticProperties.HeadingLevel="Level1" />
                <Label Text="{x:Static strings:AppStrings.MainPageDescription}"
                       FontSize="14"
                       TextColor="{DynamicResource TextMuted}" />
            </VerticalStackLayout>

            <Border Grid.Column="1"
                    x:Name="ThemePill"
                    Padding="12,8"
                    VerticalOptions="Center"
                    StrokeShape="RoundRectangle 8"
                    Stroke="{DynamicResource BorderPrimary}"
                    Background="{DynamicResource BackgroundTertiary}">
                <Border.GestureRecognizers>
                    <TapGestureRecognizer Tapped="OnThemePillTapped" />
                </Border.GestureRecognizers>
                <Label x:Name="ThemePillLabel"
                       FontSize="13"
                       VerticalOptions="Center" />
            </Border>
        </Grid>

        <!-- Main content: rail left, workspace right -->
        <Grid Grid.Row="1"
              ColumnDefinitions="72,*"
              ColumnSpacing="0">
            <ScrollView>
                <views:WorkflowRailView />
            </ScrollView>

            <Grid Grid.Column="1"
                  ZIndex="1">
                <Border Padding="16"
                        Background="{DynamicResource BackgroundSecondary}"
                        Stroke="{DynamicResource BorderPrimary}">
                    <ScrollView>
                        <Grid>
                            <views:GenerateWorkspaceView IsVisible="{Binding IsGenerateStepActive}" />
                            <views:PreviewWorkspaceView IsVisible="{Binding IsPreviewStepActive}" />
                            <views:ApplyWorkspaceView IsVisible="{Binding IsApplyStepActive}" />
                        </Grid>
                    </ScrollView>
                </Border>

                <BoxView WidthRequest="2"
                         Margin="-1,0,0,0"
                         HorizontalOptions="Start"
                         VerticalOptions="Fill"
                         BackgroundColor="{DynamicResource BackgroundSecondary}"
                         ZIndex="3" />
            </Grid>
        </Grid>
    </Grid>
</ContentPage>
