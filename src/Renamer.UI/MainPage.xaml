<?xml version="1.0" encoding="utf-8" ?>
<ContentPage xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             xmlns:model="clr-namespace:Renamer.UI.Plans"
             x:Class="Renamer.UI.MainPage">
    <Grid RowDefinitions="Auto,*"
          Padding="24"
          RowSpacing="18">
        <VerticalStackLayout Spacing="6">
            <Label Text="Plan Preview"
                   FontSize="32"
                   FontAttributes="Bold"
                   SemanticProperties.HeadingLevel="Level1" />
            <Label Text="Load a rename-plan.json artifact to review operations before apply."
                   FontSize="14"
                   TextColor="{AppThemeBinding Light=#5C5C5C, Dark=#B8B8B8}" />
        </VerticalStackLayout>

        <Grid Grid.Row="1"
              ColumnDefinitions="340,*"
              ColumnSpacing="18">
            <ScrollView>
                <VerticalStackLayout Spacing="16">
                    <Border StrokeThickness="1"
                            Padding="16">
                        <VerticalStackLayout Spacing="12">
                            <Label Text="Plan Artifact"
                                   FontSize="18"
                                   FontAttributes="Bold" />
                            <Label Text="Select or paste a path to a rename-plan.json file."
                                   FontSize="13" />
                            <Entry Text="{Binding PlanPath}"
                                   Placeholder="/path/to/rename-plan.json"
                                   ClearButtonVisibility="WhileEditing" />
                            <HorizontalStackLayout Spacing="10">
                                <Button Text="Browse"
                                        Clicked="OnBrowseClicked" />
                                <Button Text="Load Preview"
                                        Clicked="OnLoadClicked" />
                            </HorizontalStackLayout>
                            <Label Text="{Binding StatusMessage}"
                                   FontSize="13" />
                        </VerticalStackLayout>
                    </Border>

                    <Border StrokeThickness="1"
                            Padding="16"
                            IsVisible="{Binding HasError}">
                        <VerticalStackLayout Spacing="8">
                            <Label Text="Unable To Load Plan"
                                   FontSize="16"
                                   FontAttributes="Bold"
                                   TextColor="#9A3412" />
                            <Label Text="{Binding ErrorMessage}"
                                   FontSize="13" />
                        </VerticalStackLayout>
                    </Border>

                    <Border StrokeThickness="1"
                            Padding="16">
                        <VerticalStackLayout Spacing="10">
                            <Label Text="Summary"
                                   FontSize="18"
                                   FontAttributes="Bold" />
                            <CollectionView ItemsSource="{Binding SummaryItems}"
                                            SelectionMode="None">
                                <CollectionView.ItemTemplate>
                                    <DataTemplate x:DataType="model:PlanSummaryItem">
                                        <Grid ColumnDefinitions="Auto,*"
                                              ColumnSpacing="10"
                                              Padding="0,4">
                                            <Label Text="{Binding Label}"
                                                   FontAttributes="Bold" />
                                            <Label Grid.Column="1"
                                                   Text="{Binding Value}"
                                                   LineBreakMode="WordWrap" />
                                        </Grid>
                                    </DataTemplate>
                                </CollectionView.ItemTemplate>
                            </CollectionView>
                        </VerticalStackLayout>
                    </Border>
                </VerticalStackLayout>
            </ScrollView>

            <Border Grid.Column="1"
                    StrokeThickness="1"
                    Padding="16">
                <Grid RowDefinitions="Auto,*"
                      RowSpacing="12">
                    <Label Text="Operations"
                           FontSize="18"
                           FontAttributes="Bold" />

                    <Grid Grid.Row="1">
                        <Label Text="No plan loaded yet."
                               HorizontalOptions="Center"
                               VerticalOptions="Center"
                               IsVisible="{Binding IsIdle}" />

                        <ActivityIndicator IsRunning="{Binding IsLoading}"
                                           IsVisible="{Binding IsLoading}"
                                           HorizontalOptions="Center"
                                           VerticalOptions="Center" />

                        <CollectionView ItemsSource="{Binding Operations}"
                                        SelectionMode="None"
                                        IsVisible="{Binding IsLoaded}">
                            <CollectionView.ItemTemplate>
                                <DataTemplate x:DataType="model:PlanOperationItem">
                                    <Border StrokeThickness="1"
                                            Padding="14"
                                            Margin="0,0,0,10">
                                        <VerticalStackLayout Spacing="6">
                                            <Label Text="{Binding DateRangeText}"
                                                   FontSize="16"
                                                   FontAttributes="Bold" />
                                            <Label Text="{Binding FileCountText}"
                                                   FontSize="12" />
                                            <Label Text="{Binding SourcePath}"
                                                   FontSize="12"
                                                   LineBreakMode="WordWrap" />
                                            <Label Text="{Binding PlannedDestinationPath}"
                                                   FontSize="12"
                                                   LineBreakMode="WordWrap" />
                                            <Label Text="{Binding OpId}"
                                                   FontSize="11" />
                                        </VerticalStackLayout>
                                    </Border>
                                </DataTemplate>
                            </CollectionView.ItemTemplate>
                        </CollectionView>
                    </Grid>
                </Grid>
            </Border>
        </Grid>
    </Grid>

</ContentPage>
