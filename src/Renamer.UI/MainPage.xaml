<?xml version="1.0" encoding="utf-8" ?>
<ContentPage xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             xmlns:plans="clr-namespace:Renamer.UI.Plans"
             xmlns:views="clr-namespace:Renamer.UI.Views"
             x:Class="Renamer.UI.MainPage"
             x:DataType="plans:IPlanViewModel">
    <Grid RowDefinitions="Auto,*"
          Padding="24"
          RowSpacing="18">
        <VerticalStackLayout Spacing="6">
            <Label Text="Plan Generation, Preview, and Apply"
                   FontSize="32"
                   FontAttributes="Bold"
                   SemanticProperties.HeadingLevel="Level1" />
            <Label Text="Move between generation, preview, and apply at any time. Each step keeps its own status while the active workspace fills the right panel."
                   FontSize="14"
                   TextColor="{AppThemeBinding Light=#5C5C5C, Dark=#B8B8B8}" />
        </VerticalStackLayout>

        <Grid Grid.Row="1"
              ColumnDefinitions="280,*"
              ColumnSpacing="0">
            <ScrollView>
                <views:WorkflowRailView />
            </ScrollView>

            <Grid Grid.Column="1"
                  ZIndex="1">
                <Border Padding="16"
                        Background="{AppThemeBinding Light=#FFFFFF, Dark=#0F172A}"
                        Stroke="{AppThemeBinding Light=#CBD5E1, Dark=#475569}">
                    <ScrollView>
                        <Grid>
                            <views:GenerateWorkspaceView IsVisible="{Binding IsGenerateStepActive}" />
                            <views:PreviewWorkspaceView IsVisible="{Binding IsPreviewStepActive}" />
                            <views:ApplyWorkspaceView IsVisible="{Binding IsApplyStepActive}" />
                        </Grid>
                    </ScrollView>
                </Border>

                <BoxView WidthRequest="2"
                         Margin="-1,0,0,0"
                         HorizontalOptions="Start"
                         VerticalOptions="Fill"
                         BackgroundColor="{AppThemeBinding Light=#FFFFFF, Dark=#0F172A}"
                         ZIndex="3" />
            </Grid>
        </Grid>
    </Grid>
</ContentPage>
