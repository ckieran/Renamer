<?xml version="1.0" encoding="utf-8" ?>
<ContentView xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             xmlns:model="clr-namespace:Renamer.UI.Plans"
             xmlns:plans="clr-namespace:Renamer.UI.Plans"
             x:Class="Renamer.UI.Views.PreviewWorkspaceView"
             x:DataType="plans:IPlanViewModel">
    <VerticalStackLayout Spacing="18">
        <VerticalStackLayout Spacing="4">
            <Label Text="Preview Plan"
                   FontSize="24"
                   FontAttributes="Bold" />
            <Label Text="Load a plan artifact, review the summary, and inspect each planned rename operation."
                   FontSize="13"
                   TextColor="{AppThemeBinding Light=#475569, Dark=#CBD5E1}" />
        </VerticalStackLayout>

        <Border Padding="16">
            <VerticalStackLayout Spacing="12">
                <Label Text="Plan Artifact"
                       FontSize="18"
                       FontAttributes="Bold" />
                <Label Text="Select or paste a path to a rename-plan.json file."
                       FontSize="13" />
                <Entry Text="{Binding PlanPath}"
                       Placeholder="/path/to/rename-plan.json"
                       ClearButtonVisibility="WhileEditing" />
                <HorizontalStackLayout Spacing="10">
                    <Button Text="Browse"
                            Command="{Binding BrowsePlanCommand}" />
                    <Button Text="Load Preview"
                            Command="{Binding LoadPreviewCommand}" />
                </HorizontalStackLayout>
                <Label Text="{Binding StatusMessage}"
                       FontSize="13" />
            </VerticalStackLayout>
        </Border>

        <Border Padding="16"
                IsVisible="{Binding IsIdle}">
            <VerticalStackLayout Spacing="8">
                <Label Text="Preview workspace"
                       FontSize="18"
                       FontAttributes="Bold" />
                <Label Text="Select a plan artifact and load it here to review the summary first, then inspect each planned rename operation below."
                       FontSize="13" />
            </VerticalStackLayout>
        </Border>

        <Border Padding="24"
                IsVisible="{Binding IsLoading}">
            <VerticalStackLayout Spacing="12"
                                 HorizontalOptions="Center"
                                 VerticalOptions="Center">
                <ActivityIndicator IsRunning="{Binding IsLoading}"
                                   IsVisible="{Binding IsLoading}"
                                   HorizontalOptions="Center" />
                <Label Text="Loading Preview"
                       FontSize="18"
                       FontAttributes="Bold"
                       HorizontalTextAlignment="Center" />
                <Label Text="{Binding StatusMessage}"
                       FontSize="13"
                       HorizontalTextAlignment="Center" />
            </VerticalStackLayout>
        </Border>

        <Border Padding="16"
                IsVisible="{Binding HasError}">
            <VerticalStackLayout Spacing="8">
                <Label Text="Unable To Load Plan"
                       FontSize="16"
                       FontAttributes="Bold"
                       TextColor="#9A3412" />
                <Label Text="{Binding ErrorMessage}"
                       FontSize="13" />
            </VerticalStackLayout>
        </Border>

        <VerticalStackLayout Spacing="18"
                             IsVisible="{Binding IsLoaded}">
            <Border Padding="16">
                <VerticalStackLayout Spacing="16">
                    <VerticalStackLayout Spacing="4">
                        <Label Text="Summary"
                               FontSize="18"
                               FontAttributes="Bold" />
                        <Label Text="Review the loaded plan metadata before scanning through the planned rename operations."
                               FontSize="13" />
                    </VerticalStackLayout>

                    <Border Padding="14"
                            Background="{AppThemeBinding Light=#F8FAFC, Dark=#111827}">
                        <VerticalStackLayout Spacing="6">
                            <Label Text="Root Path"
                                   FontAttributes="Bold" />
                            <Label Text="{Binding RootPath}"
                                   LineBreakMode="WordWrap"
                                   TextColor="{AppThemeBinding Light=#0F4C81, Dark=#8CC8FF}">
                                <Label.GestureRecognizers>
                                    <TapGestureRecognizer Command="{Binding OpenRootPathCommand}" />
                                </Label.GestureRecognizers>
                            </Label>
                        </VerticalStackLayout>
                    </Border>

                    <Grid ColumnDefinitions="*,*,*"
                          ColumnSpacing="16">
                        <Border Grid.Column="0"
                                Padding="14"
                                Background="{AppThemeBinding Light=#F8FAFC, Dark=#111827}">
                            <VerticalStackLayout Spacing="4">
                                <Label Text="Created At"
                                       FontAttributes="Bold" />
                                <Label Text="{Binding CreatedAtDisplay}" />
                            </VerticalStackLayout>
                        </Border>

                        <Border Grid.Column="1"
                                Padding="14"
                                Background="{AppThemeBinding Light=#F8FAFC, Dark=#111827}">
                            <VerticalStackLayout Spacing="4">
                                <Label Text="Operations"
                                       FontAttributes="Bold" />
                                <Label Text="{Binding OperationCountText}" />
                            </VerticalStackLayout>
                        </Border>

                        <Border Grid.Column="2"
                                Padding="14"
                                Background="{AppThemeBinding Light=#F8FAFC, Dark=#111827}">
                            <VerticalStackLayout Spacing="4">
                                <Label Text="Warnings"
                                       FontAttributes="Bold" />
                                <Label Text="{Binding WarningCountText}" />
                            </VerticalStackLayout>
                        </Border>
                    </Grid>
                </VerticalStackLayout>
            </Border>

            <VerticalStackLayout Spacing="12">
                <Grid ColumnDefinitions="*,Auto"
                      ColumnSpacing="12">
                    <Label Text="Planned Operations"
                           FontSize="18"
                           FontAttributes="Bold" />
                    <Label Grid.Column="1"
                           Text="{Binding OperationCountText, StringFormat='{}{0} total'}"
                           FontSize="12"
                           VerticalOptions="Center"
                           TextColor="{AppThemeBinding Light=#475569, Dark=#CBD5E1}" />
                </Grid>
                <Label Text="Operations remain scrollable in the wider workspace so longer destination names and paths stay readable."
                       FontSize="13"
                       TextColor="{AppThemeBinding Light=#475569, Dark=#CBD5E1}" />

                <VerticalStackLayout Spacing="0"
                                     BindableLayout.ItemsSource="{Binding Operations}">
                    <BindableLayout.ItemTemplate>
                        <DataTemplate x:DataType="model:PlanOperationItem">
                            <Border Padding="14"
                                    Margin="0,0,0,10">
                                <VerticalStackLayout Spacing="10">
                                    <Grid ColumnDefinitions="*,Auto"
                                          ColumnSpacing="12">
                                        <VerticalStackLayout Spacing="2">
                                            <Label Text="{Binding SourceName}"
                                                   FontSize="16"
                                                   FontAttributes="Bold" />
                                            <Label Text="{Binding SourcePath}"
                                                   FontSize="12"
                                                   LineBreakMode="WordWrap"
                                                   TextColor="{AppThemeBinding Light=#5C5C5C, Dark=#B8B8B8}" />
                                        </VerticalStackLayout>

                                        <Label Grid.Column="1"
                                               Text="{Binding DateRangeText}"
                                               FontSize="12"
                                               HorizontalTextAlignment="End" />
                                    </Grid>

                                    <BoxView HeightRequest="1"
                                             BackgroundColor="{AppThemeBinding Light=#D8D8D8, Dark=#3A3A3A}" />

                                    <VerticalStackLayout Spacing="2">
                                        <Label Text="{Binding DestinationName}"
                                               FontSize="16"
                                               FontAttributes="Bold"
                                               TextColor="{AppThemeBinding Light=#0F4C81, Dark=#8CC8FF}" />
                                        <Label Text="{Binding PlannedDestinationPath}"
                                               FontSize="12"
                                               LineBreakMode="WordWrap"
                                               TextColor="{AppThemeBinding Light=#5C5C5C, Dark=#B8B8B8}" />
                                    </VerticalStackLayout>

                                    <Grid ColumnDefinitions="*,Auto"
                                          ColumnSpacing="12">
                                        <Label Text="{Binding FileCountText}"
                                               FontSize="12" />
                                        <Label Grid.Column="1"
                                               Text="{Binding OpId}"
                                               FontSize="11"
                                               HorizontalTextAlignment="End"
                                               TextColor="{AppThemeBinding Light=#808080, Dark=#9C9C9C}" />
                                    </Grid>
                                </VerticalStackLayout>
                            </Border>
                        </DataTemplate>
                    </BindableLayout.ItemTemplate>
                </VerticalStackLayout>
            </VerticalStackLayout>
        </VerticalStackLayout>
    </VerticalStackLayout>
</ContentView>
